# ─── Discord Bot ─────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here        # Tuỳ chọn: dùng khi dev để lệnh register ngay lập tức

# ─── Admin ────────────────────────────────────────────────────────────────────
# Username Discord của admin (không phải display name)
ADMIN_USERNAME=nugen.x

# ─── Game Settings ────────────────────────────────────────────────────────────
ROUND_DURATION=30000               # Thời gian mỗi ván (ms) — mặc định 30 giây
STARTING_BALANCE=1000              # Coins ban đầu cho người chơi mới
DAILY_REWARD=500                   # Phần thưởng daily
MIN_BET=10                         # Cược tối thiểu
MAX_BET=5000                       # Cược tối đa

# ─── Payout Multipliers ───────────────────────────────────────────────────────
PAYOUT_TAI=2                       # Tài: 1:1 (trả về 2x tiền cược)
PAYOUT_XIU=2                       # Xỉu: 1:1 (trả về 2x tiền cược)
PAYOUT_TRIPLE=25                   # Any Triple: 24:1 (trả về 25x tiền cược)
